{
  "name": "agentron-studio",
  "description": "Enterprise-ready local AI agent orchestration and workflow automation",
  "private": true,
  "version": "0.1.3",
  "pnpm": {
    "nodeLinker": "hoisted",
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "overrides": {
      "dmg-builder": "^26.8.1",
      "app-builder-lib": "^26.8.1",
      "electron-builder-squirrel-windows": "^26.8.1",
      "electron-builder>electron-builder-squirrel-windows": "^26.8.1",
      "app-builder-lib>electron-builder-squirrel-windows": "^26.8.1",
      "rollup": "npm:@rollup/wasm-node@4.57.1",
      "fast-xml-parser": "^5.3.6",
      "tar": "^7.5.8",
      "qs": "^6.14.2",
      "hono": "^4.11.10",
      "glob": "^10.2.2",
      "rimraf": "^5.0.0",
      "minimatch": "^10.2.1",
      "electron-builder>ajv": "6.14.0",
      "@develar/schema-utils>ajv": "6.14.0",
      "dmg-license>ajv": "6.14.0",
      "@eslint/eslintrc>ajv": "6.14.0",
      "eslint>ajv": "6.14.0"
    }
  },
  "overrides": {
    "dmg-builder": "^26.8.1",
    "app-builder-lib": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "electron-builder>electron-builder-squirrel-windows": "^26.8.1",
    "app-builder-lib>electron-builder-squirrel-windows": "^26.8.1",
    "rollup": "npm:@rollup/wasm-node@4.57.1",
    "fast-xml-parser": "^5.3.6",
    "tar": "^7.5.8",
    "qs": "^6.14.2",
    "hono": "^4.11.10",
    "glob": "^10.2.2",
    "rimraf": "^5.0.0",
    "minimatch": "^10.2.1",
    "electron-builder>ajv": "6.14.0",
    "@develar/schema-utils>ajv": "6.14.0",
    "dmg-license>ajv": "6.14.0",
    "@eslint/eslintrc>ajv": "6.14.0",
    "eslint>ajv": "6.14.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "optionalDependencies": {
    "@esbuild/win32-x64": "0.27.3",
    "@napi-rs/simple-git-win32-x64-msvc": "0.1.22",
    "@next/swc-darwin-arm64": "^16.1.6",
    "@rollup/rollup-darwin-arm64": "4.57.1",
    "@rollup/rollup-darwin-x64": "4.57.1",
    "@rollup/rollup-linux-x64-gnu": "4.57.1",
    "@rollup/rollup-win32-x64-msvc": "^4.57.1"
  },
  "scripts": {
    "postinstall": "patch-package",
    "install:full": "npm install",
    "dev:ui": "node scripts/run-workspace.mjs packages/ui dev",
    "build:ui": "node scripts/run-workspace.mjs packages/ui build",
    "lint:ui": "node scripts/run-workspace.mjs packages/ui lint",
    "typecheck": "node scripts/run-workspace.mjs all typecheck",
    "test": "node scripts/run-workspace.mjs packages/ui test",
    "test:ui": "node scripts/run-workspace.mjs packages/ui test",
    "test:coverage": "node scripts/run-workspace.mjs packages/ui test:coverage",
    "test:e2e-llm": "node scripts/run-e2e-llm.mjs",
    "install:ui": "npm install --workspace packages/ui --omit=optional",
    "install:desktop": "npm install --workspace apps/desktop --include=dev",
    "dev:docs": "node scripts/run-workspace.mjs apps/docs start",
    "docs:heap-snapshot": "node scripts/run-workspace.mjs packages/ui export-heap-snapshot",
    "build:docs": "(npm run docs:heap-snapshot || true) && node scripts/run-workspace.mjs apps/docs build",
    "serve:docs": "node scripts/run-workspace.mjs apps/docs serve",
    "count-loc": "node scripts/count-loc.js",
    "check:file-lengths": "node scripts/check-file-lengths.mjs",
    "release:bump": "node scripts/bump-version.mjs",
    "release:prepare": "npm run release:bump -- patch && npm test && npm run build:ui && npm run build:docs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && node scripts/run-workspace.mjs all typecheck && node scripts/run-workspace.mjs packages/ui lint && node scripts/run-workspace.mjs packages/ui test:coverage && node scripts/check-file-lengths.mjs",
    "pre-push": "npm run check && npm run build:ui && npm run build:docs && node scripts/run-workspace.mjs apps/desktop dist",
    "build:desktop": "npm run build:ui && node scripts/run-workspace.mjs apps/desktop build",
    "start:desktop": "node scripts/run-workspace.mjs apps/desktop build && npx electron apps/desktop",
    "dist:desktop": "npm run build:desktop && node scripts/run-workspace.mjs apps/desktop dist"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.57.1",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.2"
  }
}
