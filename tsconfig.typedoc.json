{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "downlevelIteration": true,
    "declaration": true,
    "noEmit": true
  },
  "include": ["packages/core/src/**/*", "packages/runtime/src/**/*"],
  "exclude": ["**/*.test.ts", "**/__tests__/**", "node_modules"]
}
