{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["packages/core/src/index.ts", "packages/runtime/src/index.ts"],
  "out": "apps/docs/public/technical/code-api",
  "tsconfig": "tsconfig.typedoc.json",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "exclude": ["**/*.test.ts", "**/__tests__/**", "**/node_modules/**"],
  "readme": "none",
  "plugin": [],
  "includeVersion": true
}
